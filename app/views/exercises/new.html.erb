<div class="row justify-content-center">
  <div class="col-md-6">
    <h1 class="mb-4">種目を追加</h1>

    <%= form_with model: @exercise, class: "card p-4 shadow-sm" do |f| %>
      <% if @exercise.errors.any? %>
        <div class="alert alert-danger">
          <% @exercise.errors.full_messages.each do |message| %>
            <p class="mb-0"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :name, "種目名", class: "form-label" %>
        <%= f.text_field :name, class: "form-control", placeholder: "例：ベンチプレス" %>
      </div>

      <%= f.submit "追加する", class: "btn btn-primary w-100" %>
    <% end %>

    <div class="mt-3">
      <%= link_to "戻る", exercises_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>
