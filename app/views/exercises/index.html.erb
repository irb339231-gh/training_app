<div class="row mb-4">
  <div class="col">
    <h1>種目管理</h1>
  </div>
  <div class="col-auto">
    <%= link_to "種目を追加", new_exercise_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @exercises.empty? %>
  <div class="alert alert-info">種目がまだありません</div>
<% else %>
  <div class="list-group">
    <% @exercises.each do |exercise| %>
      <div class="list-group-item d-flex justify-content-between align-items-center">
        <span><%= exercise.name %></span>
        <%= link_to "削除", exercise_path(exercise), class: "btn btn-danger btn-sm", data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
      </div>
    <% end %>
  </div>
<% end %>
