<div class="row mb-4">
  <div class="col">
    <h1>マイページ</h1>
  </div>
  <div class="col-auto">
    <%= link_to "記録を追加", new_training_log_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-4">
    <div class="card text-center">
      <div class="card-body">
        <%= link_to "記録一覧", training_logs_path, class: "btn btn-outline-primary w-100" %>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card text-center">
      <div class="card-body">
        <%= link_to "種目管理", exercises_path, class: "btn btn-outline-secondary w-100" %>
      </div>
    </div>
  </div>
</div>

<h2>トレーニングカレンダー</h2>

<%= month_calendar events: @training_logs do |date, logs| %>
  <div class="<%= logs.any? ? 'bg-success text-white' : '' %>">
    <%= date.day %>
  </div>
<% end %>

<h2>最近のトレーニング</h2>

<% if @recent_logs.empty? %>
  <div class="alert alert-info">記録がまだありません</div>
<% else %>
  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>日付</th>
          <th>種目</th>
          <th>重量(kg)</th>
          <th>回数</th>
          <th>セット数</th>
        </tr>
      </thead>
      <tbody>
        <% @recent_logs.each do |log| %>
          <tr>
            <td><%= log.date %></td>
            <td><%= log.exercise.name %></td>
            <td><%= log.weight %></td>
            <td><%= log.reps %></td>
            <td><%= log.sets %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
