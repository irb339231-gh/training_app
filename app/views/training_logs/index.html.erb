<div class="row mb-4">
  <div class="col">
    <h1>トレーニング記録</h1>
  </div>
  <div class="col-auto">
    <%= link_to "記録を追加", new_training_log_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @training_logs.empty? %>
  <div class="alert alert-info">記録がまだありません</div>
<% else %>
  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>日付</th>
          <th>種目</th>
          <th>重量(kg)</th>
          <th>回数</th>
          <th>セット数</th>
          <th>メモ</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @training_logs.each do |log| %>
          <tr>
            <td><%= log.date %></td>
            <td><%= log.exercise.name %></td>
            <td><%= log.weight %></td>
            <td><%= log.reps %></td>
            <td><%= log.sets %></td>
            <td><%= log.memo %></td>
            <td>
              <%= link_to "削除", training_log_path(log), class: "btn btn-danger btn-sm", data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>